generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ScanRun {
  id               String        @id @default(cuid())
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  inputUrl         String
  normalizedUrl    String
  status           ScanStatus    @default(QUEUED)
  error            String?
  settings         Json          @default("{}")
  progress         Json          @default("{}")
  summary          Json?
  clientEmailDraft String?
  shareToken       String?       @unique
  scheduleId       String?
  schedule         ScanSchedule? @relation(fields: [scheduleId], references: [id])
  issues           Issue[]
  pageResults      PageResult[]

  @@index([status])
  @@index([createdAt])
  @@index([normalizedUrl])
  @@index([normalizedUrl, status, createdAt])
  @@index([scheduleId])
}

model PageResult {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  scanRunId       String
  url             String
  statusCode      Int?
  loadTimeMs      Int?
  title           String?
  metaDescription String?
  h1              String?
  canonical       String?
  robotsMeta      String?
  wordCount       Int?
  links           Json?
  axeFindings     Json?
  lighthouseData  Json?
  screenshotPath  String?
  scanRun         ScanRun  @relation(fields: [scanRunId], references: [id], onDelete: Cascade)

  @@index([scanRunId])
  @@index([url])
}

model Issue {
  id           String        @id @default(cuid())
  createdAt    DateTime      @default(now())
  scanRunId    String
  code         String
  severity     Severity      @default(P2)
  category     IssueCategory
  title        String
  whyItMatters String?
  howToFix     String?
  evidence     Json?
  impact       Int?
  effort       Int?
  scanRun      ScanRun       @relation(fields: [scanRunId], references: [id], onDelete: Cascade)

  @@index([scanRunId])
  @@index([category])
  @@index([severity])
}

enum ScanStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum Severity {
  P0
  P1
  P2
  P3
}

enum IssueCategory {
  SEO
  ACCESSIBILITY
  PERFORMANCE
  LINKS
  CONTENT
  SECURITY
}

// ─────────────────────────────────────────────────────────────────────────────
// Scheduled Scans (P0 Monetization)
// ─────────────────────────────────────────────────────────────────────────────

model ScanSchedule {
  id               String            @id @default(cuid())
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  url              String            // Normalized URL to scan
  frequency        ScheduleFrequency
  enabled          Boolean           @default(true)
  lastRunAt        DateTime?
  nextRunAt        DateTime
  settings         Json              @default("{}") // Scan settings (maxPages, maxDepth, etc.)
  alertEmail       String?           // Email for alerts
  alertSlack       String?           // Slack webhook URL
  alertOnScoreDrop Int               @default(5)    // Alert if score drops by this amount
  alertOnNewP0     Boolean           @default(true)
  scanRuns         ScanRun[]

  @@index([nextRunAt, enabled])
  @@index([url])
}

enum ScheduleFrequency {
  DAILY
  WEEKLY
  MONTHLY
}
