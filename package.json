{
  "name": "site-sheriff",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@prisma/client": "^5.22.0",
    "@sentry/nextjs": "^10.43.0",
    "@supabase/supabase-js": "^2.99.1",
    "@vercel/functions": "^3.4.3",
    "better-auth": "^1.5.5",
    "cheerio": "^1.2.0",
    "next": "16.1.6",
    "openai": "^6.29.0",
    "playwright": "^1.58.2",
    "prisma": "^5.22.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "overrides": {
      "minimatch@<3.1.3": ">=3.1.3",
      "eslint>minimatch": "10.2.3",
      "@eslint/eslintrc": "3.3.4",
      "undici": ">=7.24.0",
      "flatted": ">=3.4.0"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "bash -c 'pnpm exec tsc --noEmit'"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@next/eslint-plugin-next": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.0",
    "domhandler": "^5.0.3",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  }
}
