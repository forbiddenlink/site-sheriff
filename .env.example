# Supabase Postgres (get from Supabase dashboard → Settings → Database)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Supabase client (for storage if needed)
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="..."

# OpenAI (for AI-generated client email drafts — uses gpt-4o-mini)
# If not set, falls back to the template-based email draft
OPENAI_API_KEY="sk-..."

# Optional: base URL for public share links
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Resend (for scheduled scan email alerts)
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY="re_..."
# Must be a verified sender domain in your Resend account
RESEND_FROM_EMAIL="Site Sheriff <alerts@yourdomain.com>"

# Vercel Cron secret (set in Vercel dashboard → Settings → Environment Variables)
CRON_SECRET="your-cron-secret"
